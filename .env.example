# 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ==================== API 配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_redis_password

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./skidcon.db
# DATABASE_ECHO=false

# ==================== LLM 配置 ====================
# 选择 provider: openrouter 或 openai
LLM_PROVIDER=openrouter

# OpenRouter 配置（推荐，支持多种模型）
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=z-ai/glm-5.1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=
# OPENROUTER_APP_NAME=PentestCrew

# OpenAI 配置（可选）
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o
# OPENAI_TEMPERATURE=0.7
# OPENAI_BASE_URL=

# LLM 重试配置
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0
LLM_MAX_RETRY_DELAY=30.0
LLM_TIMEOUT=60
LLM_LOG_RETRIES=true

# ==================== 向量数据库配置 ====================
VECTOR_DB_TYPE=chroma  # chroma | qdrant
VECTOR_DB_URL=http://localhost:8001
VECTOR_DB_COLLECTION=pentest_knowledge

# ==================== 图数据库配置（可选） ====================
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=pentest123

# ==================== 安全工具路径 ====================
NMAP_PATH=/usr/bin/nmap
SQLMAP_PATH=/usr/bin/sqlmap
# METASPLOIT_RPC_HOST=localhost
# METASPLOIT_RPC_PORT=55553

# ==================== Docker 沙箱配置 ====================
DOCKER_SANDBOX_ENABLED=true
DOCKER_SANDBOX_IMAGE=pentest-toolkit:latest
DOCKER_SANDBOX_TIMEOUT=300

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=logs/pentest-crew.log

# ==================== 报告配置 ====================
REPORT_OUTPUT_DIR=./reports
REPORT_FORMATS=["html", "pdf", "json"]

# ==================== 安全配置 ====================
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT=3600
SCAN_TTL=604800
ALLOWED_TARGETS=192.168.0.0/16,10.0.0.0/8

# ==================== Prompt 配置 ====================
PROMPTS_DIR=config/prompts
PROMPTS_ENABLE_RUNTIME_UPDATE=true

# ==================== 任务队列配置 ====================
QUEUE_TASK_TTL=86400
QUEUE_TASK_TIMEOUT=300
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAYS=[10,20,30]
QUEUE_DEAD_LETTER_TTL=604800

# ==================== 反弹 Shell 配置 ====================
# Docker 环境中建议设置为宿主机 IP 或 0.0.0.0
REVERSE_SHELL_LHOST=0.0.0.0
REVERSE_SHELL_LPORT=4444