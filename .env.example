# 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# 向量数据库配置
VECTOR_DB_TYPE=chroma  # chroma | qdrant
VECTOR_DB_URL=http://localhost:8001
VECTOR_DB_COLLECTION=pentest_knowledge

# 图数据库配置（可选）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pentest123

# LLM配置
LLM_PROVIDER=openai  # openai | azure | local
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# 安全工具配置
NMAP_PATH=/usr/bin/nmap
SQLMAP_PATH=/usr/bin/sqlmap
METASPLOIT_RPC_HOST=localhost
METASPLOIT_RPC_PORT=55553

# Docker沙箱配置
DOCKER_SANDBOX_ENABLED=true
DOCKER_SANDBOX_IMAGE=pentest-toolkit:latest
DOCKER_SANDBOX_TIMEOUT=300

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/pentest-crew.log

# 报告配置
REPORT_OUTPUT_DIR=./reports
REPORT_FORMATS=html,pdf,json

# 安全配置
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT=3600
ALLOWED_TARGETS=192.168.0.0/16,10.0.0.0/8